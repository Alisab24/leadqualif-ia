# Variables d'environnement pour LeadQualif IA
# Copiez ce fichier en .env.local et remplissez avec vos vraies valeurs

# Configuration Supabase
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-ici

# Configuration OpenAI (côté serveur uniquement - SÉCURISÉ)
# Pour le développement local : ajoutez cette variable dans votre environnement système
# Pour Vercel production : configurez dans Vercel Dashboard > Environment Variables
OPENAI_API_KEY=votre-cle-openai-ici

# Configuration Backend (fallback)
VITE_API_BACKEND_URL=https://leadqualif-backend.onrender.com/api
